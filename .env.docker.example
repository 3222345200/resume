APP_NAME=Resume Backend
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

POSTGRES_DB=resume_app
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=ChangeThisPostgresPassword_2026
DATABASE_URL=postgresql+psycopg://resume_user:ChangeThisPostgresPassword_2026@postgres:5432/resume_app

AUTH_SECRET_KEY=ChangeThisJwtSecret_AtLeast32Chars
AUTH_TOKEN_EXPIRE_MINUTES=10080
AUTH_CAPTCHA_EXPIRE_MINUTES=5
AUTH_EMAIL_CODE_EXPIRE_MINUTES=10
AUTH_EMAIL_CODE_COOLDOWN_SECONDS=60

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-user
SMTP_PASSWORD=ChangeThisSmtpPassword
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=OfferPilot
SMTP_USE_SSL=false
SMTP_USE_STARTTLS=true

MINIO_ROOT_USER=resumeadmin
MINIO_ROOT_PASSWORD=ChangeThisMinioRootPassword_2026
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=your-server-ip:9000
MINIO_ACCESS_KEY=resumeadmin
MINIO_SECRET_KEY=ChangeThisMinioRootPassword_2026
MINIO_BUCKET=resume-pdfs
MINIO_SECURE=false
MINIO_PDF_PREFIX=resumes
MINIO_AVATAR_PREFIX=avatars
MINIO_PRESIGNED_EXPIRE_MINUTES=60
