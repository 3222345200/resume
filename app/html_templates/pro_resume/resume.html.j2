<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
  <style>
    :root {
      --layout-section-title-size: {{ layout.section_title_size }};
      --layout-content-font-size: {{ layout.content_font_size }};
      --layout-content-line-height: {{ layout.content_line_height }};
      --layout-section-divider-gap: {{ layout.section_divider_gap }};
      --layout-entry-title-size: calc(var(--layout-content-font-size) + 1.9px);
      --layout-emphasis-font-size: calc(var(--layout-content-font-size) + 0.5px);
      --layout-font-color: {{ layout.font_color }};
    }

    @page {
      size: A4;
      margin: 5mm 15mm;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: "Times New Roman", "SimSun", "Songti SC", serif;
      color: var(--layout-font-color);
      background: #ffffff;
      font-size: 12.4px;
      line-height: 1.4;
      letter-spacing: 0.01em;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .page {
      width: 100%;
      background: #ffffff;
    }

    .topbar {
      position: relative;
      min-height: 100px;
      padding-top: 2px;
      padding-bottom: 2px;
    }

    .avatar-wrap {
      position: absolute;
      bottom: 2px;
      right: 0;
      width: 2.15cm;
      height: 3.01cm;
      overflow: hidden;
      background: #ffffff;
    }

    .avatar {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      background: #ffffff;
      transform-origin: center center;
    }

    .name {
      margin: 18px 0 3px;
      text-align: center;
      font-family: "FangSong", "STFangsong", "SimSun", serif;
      font-size: 22px;
      font-weight: 700;
      letter-spacing: 0.015em;
      line-height: 1.12;
    }

    .contact {
      text-align: center;
      font-size: 12.5px;
      line-height: 1.35;
    }

    .contact strong {
      font-weight: 700;
    }

    .contact em {
      font-style: italic;
    }

    .divider-dot {
      display: inline-block;
      margin: 0 0.16em;
    }

    .job-target {
      margin-top: 1px;
      font-family: "KaiTi", "STKaiti", "Kaiti SC", serif;
      font-size: 13.2px;
      line-height: 1.25;
    }

    .section {
      margin-top: 7px;
    }

    .topbar + .section {
      margin-top: -20px;
    }

    .section-title {
      margin: 0 0 calc(var(--layout-section-divider-gap) * 0.5);
      padding-bottom: var(--layout-section-divider-gap);
      border-bottom: 1.5pt solid var(--layout-font-color);
      font-size: var(--layout-section-title-size);
      font-family: "FangSong", "STFangsong", serif;
      font-weight: 700;
      line-height: 1.15;
    }

    .section-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 16px;
      height: 16px;
      margin-right: 8px;
      transform: translateY(1px);
      color: var(--layout-font-color);
    }

    .section-icon svg {
      width: 16px;
      height: 16px;
      stroke: currentColor;
      fill: none;
      stroke-width: 1.8;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .entry {
      margin-top: 4px;
    }

    .entry-head {
      display: table;
      width: 100%;
      table-layout: fixed;
      margin-bottom: 1px;
    }

    .entry-left,
    .entry-right {
      display: table-cell;
      vertical-align: top;
    }

    .entry-right {
      width: 35%;
      text-align: right;
      font-weight: 700;
    }

    .entry-title {
      font-size: var(--layout-entry-title-size);
      font-family: "KaiTi", "STKaiti", serif;
      line-height: var(--layout-content-line-height);
    }

    .entry-title strong {
      font-weight: 700;
    }

    .education-head {
      display: grid;
      grid-template-columns: minmax(0, 1.45fr) minmax(0, 1.3fr) minmax(4.5em, 0.65fr) auto;
      column-gap: 1.1em;
      align-items: start;
    }

    .education-head .entry-right {
      width: auto;
      white-space: nowrap;
    }

    .education-cell {
      min-width: 0;
    }

    .education-school,
    .education-major,
    .education-degree {
      text-align: left;
    }

    .research-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      column-gap: 1em;
      align-items: baseline;
    }

    .research-head .entry-left,
    .research-head .entry-right {
      display: block;
      min-width: 0;
    }

    .research-head .entry-left {
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .research-head .entry-right {
      width: auto;
      white-space: nowrap;
    }

    .role-line {
      margin-top: -1px;
      margin-bottom: 2px;
      font-family: "KaiTi", "STKaiti", serif;
      font-size: var(--layout-content-font-size);
      line-height: var(--layout-content-line-height);
      font-weight: 700;
    }

    .role-line em {
      font-style: italic;
      font-weight: 400;
    }

    .entry-tag {
      display: inline-flex;
      align-items: center;
      margin-right: 0.5em;
      padding: 1px 7px;
      border: 1px solid rgba(31, 41, 55, 0.25);
      border-radius: 999px;
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: #1f2937;
      background: rgba(31, 41, 55, 0.04);
      transform: translateY(-1px);
    }

    .location-chip {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      margin-left: 0.45em;
      font-size: 12px;
      font-weight: 400;
      color: #374151;
    }

    .location-chip svg {
      width: 11px;
      height: 11px;
      stroke: currentColor;
      fill: none;
      stroke-width: 1.8;
      stroke-linecap: round;
      stroke-linejoin: round;
      flex-shrink: 0;
    }

    .rich {
      font-family: "KaiTi", "STKaiti", "Kaiti SC", serif;
      font-size: var(--layout-content-font-size);
      line-height: var(--layout-content-line-height);
      word-break: break-word;
    }

    .rich p,
    .rich ul,
    .rich ol {
      margin-top: 0;
      margin-bottom: 0.2em;
    }

    .rich p:last-child,
    .rich ul:last-child,
    .rich ol:last-child {
      margin-bottom: 0;
    }

    .rich ul,
    .rich ol {
      padding-left: 1.45em;
    }

    .rich li {
      margin: 0.08em 0;
    }

    .education-lines .line {
      margin: 0.08em 0;
      font-family: "KaiTi", "STKaiti", serif;
      font-size: var(--layout-emphasis-font-size);
      line-height: var(--layout-content-line-height);
    }

    .education-lines .line::before {
      content: "?";
      display: inline-block;
      width: 1em;
    }

    .skills-text {
      font-family: "KaiTi", "STKaiti", serif;
      font-size: var(--layout-content-font-size);
      line-height: var(--layout-content-line-height);
    }

    .skills-text p {
      margin: 0 0 0.1em;
    }

    .project-prefix {
      margin-bottom: 0.1em;
      font-family: "KaiTi", "STKaiti", serif;
      font-size: var(--layout-emphasis-font-size);
      line-height: var(--layout-content-line-height);
      font-weight: 700;
    }

    .project-list ol {
      list-style: decimal;
      padding-left: 1.6em;
    }

    .research-summary,
    .honor-summary,
    .self-summary {
      margin-top: 1px;
    }

    .portfolio-link {
      margin-top: 1px;
      font-family: "KaiTi", "STKaiti", serif;
      font-size: 13.5px;
      word-break: break-all;
    }

    a {
      color: inherit;
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="topbar">
      {% if basics.avatar_data_uri %}
        <div class="avatar-wrap">
          <img class="avatar" src="{{ basics.avatar_data_uri }}" alt="avatar" style="object-position: {{ basics.avatar_crop.offset_x }}% {{ basics.avatar_crop.offset_y }}%; transform: scale({{ basics.avatar_crop.scale }});">
        </div>
      {% endif %}

      <h1 class="name">{{ basics.name or title }}</h1>

      <div class="contact">
        {% if basics.phone %}<strong>(+86){{ basics.phone }}</strong>{% endif %}
        {% if basics.phone and basics.email %}<span class="divider-dot">|</span>{% endif %}
        {% if basics.email %}<strong><em>{{ basics.email }}</em></strong>{% endif %}
        {% if basics.job_target %}
          <div class="job-target">求职意向：{{ basics.job_target }}</div>
        {% endif %}
      </div>
    </div>
    {% if basics.summary %}
      <section class="section">
        <h2 class="section-title">
          <span class="section-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"></circle><path d="M5 20c1.5-3.5 4-5 7-5s5.5 1.5 7 5"></path></svg>
          </span>个人简介
        </h2>
        <div class="rich self-summary">{{ basics.summary | safe }}</div>
      </section>
    {% endif %}

    {% if education %}
      <section class="section">
        <h2 class="section-title">
          <span class="section-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M3 8l9-4 9 4-9 4-9-4Z"></path><path d="M7 10.5v4.2c0 .8 2.2 2.3 5 2.3s5-1.5 5-2.3v-4.2"></path><path d="M21 9v6"></path></svg>
          </span>教育经历
        </h2>
        {% for item in education %}
          <div class="entry">
            <div class="entry-head education-head">
              <div class="entry-left entry-title education-cell education-school">
                <strong>{{ item.school }}</strong>
              </div>
              <div class="entry-title education-cell education-major">
                {% if item.major %}<strong>{{ item.major }}</strong>{% endif %}
              </div>
              <div class="entry-title education-cell education-degree">
                {% if item.degree %}<strong>{{ item.degree }}</strong>{% endif %}
              </div>
              <div class="entry-right">{{ item.start_date }}{% if item.start_date and item.end_date %} ~ {% endif %}{{ item.end_date }}</div>
            </div>
            {% if item.highlights %}
              <div class="education-lines rich">{{ item.highlights | safe }}</div>
            {% endif %}
          </div>
        {% endfor %}
      </section>
    {% endif %}

    {% for section in ordered_sections %}
      {% if section["key"] == "skills" %}
        <section class="section">
          <h2 class="section-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M14 6l4 4"></path><path d="M4 20l5.5-1 9-9a2.1 2.1 0 0 0-3-3l-9 9L4 20Z"></path><path d="M12 8l4 4"></path></svg>
            </span>{{ section["title"] }}
          </h2>
          <div class="skills-text rich">{{ section["content"] | safe }}</div>
        </section>
      {% elif section["key"] == "experience" %}
        <section class="section">
          <h2 class="section-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><rect x="4" y="7" width="16" height="12" rx="2"></rect><path d="M9 7V5h6v2"></path><path d="M4 12h16"></path></svg>
            </span>{{ section["title"] }}
          </h2>
          {% for item in section["items"] %}
            <div class="entry">
              <div class="entry-head">
                <div class="entry-left entry-title">
                  <span class="entry-tag">{{ item.entry_type or "实习经历" }}</span>
                  <strong>{{ item.company }}</strong>
                  {% if item.location %}
                    <span class="location-chip">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s-6-4.35-6-10a6 6 0 1 1 12 0c0 5.65-6 10-6 10Z"></path><circle cx="12" cy="11" r="2.2"></circle></svg>
                      {{ item.location }}
                    </span>
                  {% endif %}
                </div>
                <div class="entry-right">{{ item.start_date }}{% if item.start_date and item.end_date %} ~ {% endif %}{{ item.end_date }}</div>
              </div>
              {% if item.department or item.role %}
                <div class="role-line">{{ item.department }}{% if item.department and item.role %} <em>{{ item.role }}</em>{% else %}{% if item.role %}<em>{{ item.role }}</em>{% endif %}{% endif %}</div>
              {% endif %}
              {% if item.highlights %}
                <div class="rich">{{ item.highlights | safe }}</div>
              {% endif %}
            </div>
          {% endfor %}
        </section>
      {% elif section["key"] == "projects" %}
        <section class="section">
          <h2 class="section-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"></rect><path d="M8 19v2"></path><path d="M16 19v2"></path><path d="M8 9h8"></path><path d="M8 13h5"></path></svg>
            </span>{{ section["title"] }}
          </h2>
          {% for item in section["items"] %}
            <div class="entry">
              <div class="entry-head">
                <div class="entry-left entry-title"><strong>{{ item.name }}</strong></div>
                <div class="entry-right">{{ item.start_date }}{% if item.start_date and item.end_date %} ~ {% endif %}{{ item.end_date }}</div>
              </div>
              {% if item.description %}
                <div class="role-line">项目描述：<em>{{ item.description }}</em></div>
              {% endif %}
              {% if item.highlights %}
                <div class="project-prefix">主要工作</div>
                <div class="rich project-list">{{ item.highlights | safe }}</div>
              {% endif %}
            </div>
          {% endfor %}
        </section>
      {% elif section["key"] == "portfolio" %}
        <section class="section">
          <h2 class="section-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.1 0l2.4-2.4a5 5 0 0 0-7.1-7.1L10 5"></path><path d="M14 11a5 5 0 0 0-7.1 0l-2.4 2.4a5 5 0 0 0 7.1 7.1L14 19"></path></svg>
            </span>{{ section["title"] }}
          </h2>
          {% for item in section["items"] %}
            <div class="entry">
              <div class="entry-head">
                <div class="entry-left entry-title">{{ item.title }}</div>
                <div class="entry-right"></div>
              </div>
              {% if item.link %}
                <div class="portfolio-link"><a href="{{ item.link }}">{{ item.link }}</a></div>
              {% endif %}
              {% if item.summary %}
                <div class="rich">{{ item.summary | safe }}</div>
              {% endif %}
            </div>
          {% endfor %}
        </section>
      {% elif section["key"] == "research" %}
        <section class="section">
          <h2 class="section-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M6 4h9l3 3v13H6z"></path><path d="M15 4v3h3"></path><path d="M9 12h6"></path><path d="M9 16h4"></path></svg>
            </span>{{ section["title"] }}
          </h2>
          {% for item in section["items"] %}
            <div class="entry">
              <div class="entry-head research-head">
                <div class="entry-left entry-title">{{ item.title }}</div>
                <div class="entry-right">{{ item.label }}</div>
              </div>
              {% if item.summary %}
                <div class="rich research-summary">{{ item.summary | safe }}</div>
              {% endif %}
            </div>
          {% endfor %}
        </section>
      {% elif section["key"] == "honors" %}
        <section class="section">
          <h2 class="section-title">
            <span class="section-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"></circle><path d="M10 12l-2 8 4-2 4 2-2-8"></path></svg>
            </span>{{ section["title"] }}
          </h2>
          {% for item in section["items"] %}
            <div class="entry">
              <div class="entry-head">
                <div class="entry-left entry-title">{{ item.title }}</div>
                <div class="entry-right">{{ item.label }}</div>
              </div>
              {% if item.summary %}
                <div class="rich honor-summary">{{ item.summary | safe }}</div>
              {% endif %}
            </div>
          {% endfor %}
        </section>
      {% endif %}
    {% endfor %}
  </div>
</body>
</html>
