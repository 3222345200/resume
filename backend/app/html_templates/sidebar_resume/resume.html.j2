<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
  <style>
    :root {
      --layout-section-title-size: {{ layout.section_title_size }};
      --layout-content-font-size: {{ layout.content_font_size }};
      --layout-content-line-height: {{ layout.content_line_height }};
      --layout-section-title-font-family: {{ layout.section_title_font_family }};
      --layout-content-font-family: {{ layout.content_font_family }};
      --layout-section-title-color: {{ layout.section_title_color }};
      --layout-content-font-color: {{ layout.content_font_color }};
      --sidebar-accent: #0f766e;
      --sidebar-deep: #0b3d3b;
      --paper-bg: #f8fafc;
      --paper-line: rgba(15, 23, 42, 0.1);
    }

    @page {
      size: A4;
      margin: 0;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: var(--layout-content-font-family);
      color: var(--layout-content-font-color);
      background: #edf2f7;
      font-size: 12.4px;
      line-height: 1.45;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .page {
      width: 210mm;
      height: 297mm;
      padding: 0;
      overflow: hidden;
      background: #ffffff;
      break-after: page;
      page-break-after: always;
    }

    .page:last-child {
      break-after: auto;
      page-break-after: auto;
    }

    @media screen {
      body {
        padding: 8px;
      }

      .page {
        margin: 0 auto 12px;
        box-shadow: 0 18px 42px rgba(15, 23, 42, 0.16);
      }
    }

    .resume-shell {
      display: grid;
      grid-template-columns: 62mm minmax(0, 1fr);
      min-height: 297mm;
    }

    .sidebar {
      min-height: 100%;
      padding: 10mm 7mm 9mm;
      color: rgba(255, 255, 255, 0.96);
      background:
        radial-gradient(circle at top left, rgba(255, 255, 255, 0.16), transparent 26%),
        linear-gradient(180deg, var(--sidebar-accent) 0%, var(--sidebar-deep) 100%);
    }

    .main {
      padding: 8mm 10mm 8mm 9mm;
      background:
        linear-gradient(180deg, rgba(248, 250, 252, 0.96), rgba(255, 255, 255, 0.98));
    }

    .avatar-wrap {
      width: 34mm;
      height: 47.6mm;
      margin: 0 auto 7mm;
      overflow: hidden;
      border-radius: 18px;
      border: 1.5px solid rgba(255, 255, 255, 0.24);
      background: rgba(255, 255, 255, 0.1);
      box-shadow: 0 14px 28px rgba(0, 0, 0, 0.16);
    }

    .avatar {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transform-origin: center center;
    }

    .sidebar-name {
      margin: 0;
      font-family: var(--layout-section-title-font-family);
      font-size: 22px;
      line-height: 1.1;
      text-align: center;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    .sidebar-job-target {
      margin: 7px 0 0;
      text-align: center;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.08em;
      opacity: 0.9;
    }

    .sidebar-contact {
      display: grid;
      gap: 8px;
      margin-top: 7mm;
      font-size: 12px;
      line-height: 1.5;
    }

    .sidebar-contact-item {
      padding: 8px 10px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.1);
      word-break: break-word;
    }

    .sidebar-section {
      margin-top: 7mm;
    }

    .sidebar-section-title,
    .section-title {
      margin: 0 0 8px;
      font-family: var(--layout-section-title-font-family);
      font-size: var(--layout-section-title-size);
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: 0.02em;
    }

    .sidebar-section-title {
      padding-bottom: 6px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.22);
      color: #ffffff;
    }

    .section {
      margin-top: 6mm;
      padding-bottom: 4mm;
      border-bottom: 1px solid var(--paper-line);
    }

    .section:first-child {
      margin-top: 0;
    }

    .section:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .section-title {
      color: var(--layout-section-title-color);
    }

    .rich {
      font-size: var(--layout-content-font-size);
      line-height: var(--layout-content-line-height);
      word-break: break-word;
    }

    .rich p,
    .rich ul,
    .rich ol {
      margin-top: 0;
      margin-bottom: 0.22em;
    }

    .rich ul,
    .rich ol {
      padding-left: 1.4em;
    }

    .entry {
      margin-top: 10px;
    }

    .entry:first-of-type {
      margin-top: 0;
    }

    .entry-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 10px;
      align-items: baseline;
      margin-bottom: 2px;
    }

    .entry-title {
      min-width: 0;
      font-size: calc(var(--layout-content-font-size) + 1.3px);
      font-weight: 700;
    }

    .entry-right {
      white-space: nowrap;
      font-weight: 700;
      font-size: 12px;
      color: rgba(15, 23, 42, 0.72);
    }

    .entry-subtitle {
      margin-bottom: 3px;
      font-size: var(--layout-content-font-size);
      font-weight: 700;
      color: rgba(15, 23, 42, 0.76);
    }

    .entry-label {
      display: inline-block;
      margin-right: 8px;
      padding: 1px 8px;
      border-radius: 999px;
      background: rgba(15, 118, 110, 0.08);
      color: var(--sidebar-accent);
      font-size: 11px;
      font-weight: 700;
    }

    .sidebar .rich {
      color: rgba(255, 255, 255, 0.96);
    }

    .sidebar .rich ul,
    .sidebar .rich ol {
      padding-left: 1.2em;
    }

    a {
      color: inherit;
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="resume-shell">
      <aside class="sidebar" data-section-key="basics">
        {% if basics.avatar_data_uri %}
          <div class="avatar-wrap">
            <img class="avatar" src="{{ basics.avatar_data_uri }}" alt="avatar" style="object-position: 50% 50%; transform: translate({{ (50 - basics.avatar_crop.offset_x) * (0.45 + (basics.avatar_crop.scale - 1) * 0.9) }}%, {{ (50 - basics.avatar_crop.offset_y) * (0.45 + (basics.avatar_crop.scale - 1) * 0.9) }}%) scale({{ basics.avatar_crop.scale }});">
          </div>
        {% endif %}
        <h1 class="sidebar-name">{{ basics.name or title }}</h1>
        {% if basics.job_target %}<p class="sidebar-job-target">{{ basics.job_target }}</p>{% endif %}

        <div class="sidebar-contact">
          {% if basics.phone %}<div class="sidebar-contact-item">电话：{{ basics.phone }}</div>{% endif %}
          {% if basics.email %}<div class="sidebar-contact-item">邮箱：{{ basics.email }}</div>{% endif %}
          {% if basics.location %}<div class="sidebar-contact-item">意向城市：{{ basics.location }}</div>{% endif %}
        </div>

        {% for section in ordered_sections %}
          {% if section["key"] == "skills" %}
            <section class="sidebar-section" data-section-key="{{ section['key'] }}">
              <h2 class="sidebar-section-title">{{ section["title"] }}</h2>
              <div class="rich">{{ section["content"] | safe }}</div>
            </section>
          {% endif %}
        {% endfor %}

        {% if basics.summary %}
          <section class="sidebar-section" data-section-key="basics">
            <h2 class="sidebar-section-title">个人简介</h2>
            <div class="rich">{{ basics.summary | safe }}</div>
          </section>
        {% endif %}
      </aside>

      <main class="main">
        {% if education %}
          <section class="section" data-section-key="education">
            <h2 class="section-title">教育经历</h2>
            {% for item in education %}
              <div class="entry">
                <div class="entry-head">
                  <div class="entry-title">{{ item.school }}{% if item.major %} / {{ item.major }}{% endif %}{% if item.degree %} / {{ item.degree }}{% endif %}</div>
                  <div class="entry-right">{{ item.start_date }}{% if item.start_date and item.end_date %} - {% endif %}{{ item.end_date }}</div>
                </div>
                {% if item.highlights %}<div class="rich">{{ item.highlights | safe }}</div>{% endif %}
              </div>
            {% endfor %}
          </section>
        {% endif %}

        {% for section in ordered_sections %}
          {% if section["key"] == "skills" %}
          {% elif section["key"] == "experience" %}
            <section class="section" data-section-key="{{ section['key'] }}">
              <h2 class="section-title">{{ section["title"] }}</h2>
              {% for item in section["items"] %}
                <div class="entry">
                  <div class="entry-head">
                    <div class="entry-title"><span class="entry-label">{{ item.entry_type or "实习经历" }}</span>{{ item.company }}</div>
                    <div class="entry-right">{{ item.start_date }}{% if item.start_date and item.end_date %} - {% endif %}{{ item.end_date }}</div>
                  </div>
                  {% if item.department or item.role or item.location %}
                    <div class="entry-subtitle">{{ item.department }}{% if item.department and item.role %} / {% endif %}{{ item.role }}{% if item.location %} · {{ item.location }}{% endif %}</div>
                  {% endif %}
                  {% if item.highlights %}<div class="rich">{{ item.highlights | safe }}</div>{% endif %}
                </div>
              {% endfor %}
            </section>
          {% elif section["key"] == "projects" %}
            <section class="section" data-section-key="{{ section['key'] }}">
              <h2 class="section-title">{{ section["title"] }}</h2>
              {% for item in section["items"] %}
                <div class="entry">
                  <div class="entry-head">
                    <div class="entry-title">{{ item.name }}</div>
                    <div class="entry-right">{{ item.start_date }}{% if item.start_date and item.end_date %} - {% endif %}{{ item.end_date }}</div>
                  </div>
                  {% if item.description %}<div class="rich">{{ item.description | safe }}</div>{% endif %}
                  {% if item.highlights %}<div class="rich">{{ item.highlights | safe }}</div>{% endif %}
                </div>
              {% endfor %}
            </section>
          {% elif section["key"] == "portfolio" %}
            <section class="section" data-section-key="{{ section['key'] }}">
              <h2 class="section-title">{{ section["title"] }}</h2>
              {% for item in section["items"] %}
                <div class="entry">
                  <div class="entry-head">
                    <div class="entry-title">{{ item.title }}</div>
                  </div>
                  {% if item.link %}<div class="rich"><a href="{{ item.link }}">{{ item.link }}</a></div>{% endif %}
                  {% if item.summary %}<div class="rich">{{ item.summary | safe }}</div>{% endif %}
                </div>
              {% endfor %}
            </section>
          {% elif section["key"] == "research" or section["key"] == "honors" %}
            <section class="section" data-section-key="{{ section['key'] }}">
              <h2 class="section-title">{{ section["title"] }}</h2>
              {% for item in section["items"] %}
                <div class="entry">
                  <div class="entry-head">
                    <div class="entry-title">{{ item.title }}</div>
                    <div class="entry-right">{{ item.label }}</div>
                  </div>
                  {% if item.summary %}<div class="rich">{{ item.summary | safe }}</div>{% endif %}
                </div>
              {% endfor %}
            </section>
          {% elif section.get("kind") == "custom" %}
            <section class="section" data-section-key="{{ section['key'] }}">
              <h2 class="section-title">{{ section["title"] }}</h2>
              {% for item in section["items"] %}
                <div class="entry">
                  <div class="entry-head">
                    <div class="entry-title">{{ item.title }}</div>
                    <div class="entry-right">{{ item.start_date }}{% if item.start_date and item.end_date %} - {% endif %}{{ item.end_date }}</div>
                  </div>
                  {% if item.subtitle %}<div class="entry-subtitle">{{ item.subtitle }}</div>{% endif %}
                  {% if item.description %}<div class="rich">{{ item.description | safe }}</div>{% endif %}
                  {% if item.highlights %}<div class="rich">{{ item.highlights | safe }}</div>{% endif %}
                </div>
              {% endfor %}
            </section>
          {% endif %}
        {% endfor %}
      </main>
    </div>
  </div>
  <script>
    (function enableSectionJumping() {
      const notifyParent = function (sectionKey) {
        if (!sectionKey || window.parent === window) {
          return;
        }
        window.parent.postMessage({
          type: 'resume-preview-section-dblclick',
          sectionKey: sectionKey,
        }, window.location.origin);
      };

      document.addEventListener('dblclick', function (event) {
        const sectionNode = event.target.closest('[data-section-key]');
        if (!sectionNode) {
          return;
        }
        notifyParent(sectionNode.getAttribute('data-section-key'));
      });
    })();

    (function paginateResumePages() {
      const runPagination = function () {
        if (document.body.dataset.resumePaginated === '1') {
          return;
        }

        const sourcePage = document.querySelector('.page');
        const sourceShell = sourcePage && sourcePage.querySelector(':scope > .resume-shell');
        const sourceSidebar = sourceShell && sourceShell.querySelector(':scope > .sidebar');
        const sourceMain = sourceShell && sourceShell.querySelector(':scope > .main');
        if (!sourcePage || !sourceShell || !sourceSidebar || !sourceMain) {
          return;
        }

        const sectionNodes = Array.from(sourceMain.querySelectorAll(':scope > .section'));
        const pageStack = document.createElement('div');
        pageStack.className = 'page-stack';
        sourcePage.after(pageStack);

        const createPage = function () {
          const page = sourcePage.cloneNode(false);
          const shell = sourceShell.cloneNode(false);
          const sidebar = sourceSidebar.cloneNode(true);
          const main = sourceMain.cloneNode(false);
          shell.appendChild(sidebar);
          shell.appendChild(main);
          page.appendChild(shell);
          pageStack.appendChild(page);
          return { page: page, main: main };
        };

        const pageHasBodyContent = function (pageInfo) {
          return pageInfo.main.children.length > 0;
        };

        const pageOverflows = function (pageInfo) {
          return pageInfo.page.scrollHeight > pageInfo.page.clientHeight + 1;
        };

        const buildSectionShell = function (sectionNode) {
          const sectionShell = sectionNode.cloneNode(false);
          const titleNode = sectionNode.querySelector(':scope > .section-title');
          if (titleNode) {
            sectionShell.appendChild(titleNode.cloneNode(true));
          }
          return sectionShell;
        };

        let currentPage = createPage();

        const ensureSectionShell = function (sectionNode) {
          let sectionShell = buildSectionShell(sectionNode);
          currentPage.main.appendChild(sectionShell);

          if (pageOverflows(currentPage) && pageHasBodyContent(currentPage)) {
            sectionShell.remove();
            currentPage = createPage();
            sectionShell = buildSectionShell(sectionNode);
            currentPage.main.appendChild(sectionShell);
          }

          return sectionShell;
        };

        const appendWholeSection = function (sectionNode) {
          const sectionClone = sectionNode.cloneNode(true);
          currentPage.main.appendChild(sectionClone);

          if (!pageOverflows(currentPage)) {
            return true;
          }

          sectionClone.remove();
          if (pageHasBodyContent(currentPage)) {
            currentPage = createPage();
            currentPage.main.appendChild(sectionNode.cloneNode(true));
            if (!pageOverflows(currentPage)) {
              return true;
            }
            currentPage.main.lastElementChild.remove();
          }

          return false;
        };

        const appendSectionByBlocks = function (sectionNode) {
          const blockNodes = Array.from(sectionNode.children).filter(function (child) {
            return !child.classList.contains('section-title');
          });
          let sectionShell = ensureSectionShell(sectionNode);

          blockNodes.forEach(function (blockNode) {
            const blockClone = blockNode.cloneNode(true);
            sectionShell.appendChild(blockClone);

            if (!pageOverflows(currentPage)) {
              return;
            }

            blockClone.remove();
            if (sectionShell.children.length <= 1 && !pageHasBodyContent(currentPage)) {
              sectionShell.appendChild(blockNode.cloneNode(true));
              return;
            }

            if (sectionShell.children.length <= 1) {
              sectionShell.remove();
            }
            currentPage = createPage();
            sectionShell = buildSectionShell(sectionNode);
            currentPage.main.appendChild(sectionShell);
            sectionShell.appendChild(blockNode.cloneNode(true));
          });

          if (sectionShell.children.length <= 1) {
            sectionShell.remove();
          }
        };

        sectionNodes.forEach(function (sectionNode) {
          if (!appendWholeSection(sectionNode)) {
            appendSectionByBlocks(sectionNode);
          }
        });

        sourcePage.remove();
        document.body.dataset.resumePaginated = '1';
      };

      if (document.readyState === 'complete') {
        requestAnimationFrame(runPagination);
      } else {
        window.addEventListener('load', function () {
          requestAnimationFrame(runPagination);
        }, { once: true });
      }
    })();
  </script>
</body>
</html>
