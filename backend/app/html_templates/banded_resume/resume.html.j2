<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <title>{{ title }}</title>
  <style>
    :root {
      --layout-section-title-size: {{ layout.section_title_size }};
      --layout-content-font-size: {{ layout.content_font_size }};
      --layout-content-line-height: {{ layout.content_line_height }};
      --layout-section-title-font-family: {{ layout.section_title_font_family }};
      --layout-content-font-family: {{ layout.content_font_family }};
      --layout-section-title-color: {{ layout.section_title_color }};
      --layout-content-font-color: {{ layout.content_font_color }};
      --band-bg: #1f2937;
      --band-accent: #d4af37;
      --paper-bg: #fffdf8;
      --paper-line: rgba(31, 41, 55, 0.12);
    }

    @page {
      size: A4;
      margin: 0;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      background: #f1f5f9;
      font-family: var(--layout-content-font-family);
      color: var(--layout-content-font-color);
      font-size: 12.4px;
      line-height: 1.45;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .page {
      width: 210mm;
      height: 297mm;
      padding: 10mm 12mm 10mm;
      background:
        linear-gradient(180deg, rgba(255, 253, 248, 0.98), rgba(255, 255, 255, 1));
      overflow: hidden;
      break-after: page;
      page-break-after: always;
    }

    .page:last-child {
      break-after: auto;
      page-break-after: auto;
    }

    @media screen {
      body {
        padding: 8px;
      }

      .page {
        margin: 0 auto 12px;
        box-shadow: 0 18px 42px rgba(15, 23, 42, 0.14);
      }
    }

    .header {
      padding: 8mm 8mm 6mm;
      border-radius: 22px;
      background:
        radial-gradient(circle at top right, rgba(212, 175, 55, 0.2), transparent 24%),
        linear-gradient(135deg, #111827 0%, #1f2937 100%);
      color: #f8fafc;
    }

    .header-top {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 16px;
      align-items: center;
    }

    .name {
      margin: 0;
      font-family: var(--layout-section-title-font-family);
      font-size: 28px;
      line-height: 1.05;
      letter-spacing: 0.02em;
    }

    .header-meta {
      margin-top: 8px;
      font-size: 13px;
      line-height: 1.7;
      color: rgba(248, 250, 252, 0.92);
    }

    .header-meta strong {
      color: #ffffff;
    }

    .avatar-wrap {
      width: 1.88cm;
      height: 2.63cm;
      overflow: hidden;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      background: rgba(255, 255, 255, 0.08);
    }

    .avatar {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transform-origin: center center;
    }

    .summary-band {
      margin-top: 10px;
      padding-top: 10px;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
    }

    .section {
      margin-top: 6mm;
    }

    .section-title {
      display: inline-block;
      min-width: 42mm;
      margin: 0 0 8px;
      padding: 6px 14px 7px;
      border-radius: 999px;
      background: var(--band-bg);
      color: #ffffff;
      font-family: var(--layout-section-title-font-family);
      font-size: var(--layout-section-title-size);
      font-weight: 700;
      line-height: 1.1;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
    }

    .entry {
      margin-top: 10px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--paper-line);
    }

    .entry:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .entry-head {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 10px;
      align-items: baseline;
      margin-bottom: 3px;
    }

    .entry-title {
      min-width: 0;
      font-size: calc(var(--layout-content-font-size) + 1.5px);
      font-weight: 700;
    }

    .entry-right {
      white-space: nowrap;
      color: rgba(31, 41, 55, 0.72);
      font-size: 12px;
      font-weight: 700;
    }

    .entry-subtitle {
      margin-bottom: 3px;
      font-size: var(--layout-content-font-size);
      font-weight: 700;
      color: rgba(31, 41, 55, 0.78);
    }

    .entry-tag {
      display: inline-block;
      margin-right: 8px;
      padding: 1px 8px;
      border-radius: 999px;
      background: rgba(212, 175, 55, 0.14);
      color: #7c5f10;
      font-size: 11px;
      font-weight: 700;
    }

    .rich {
      font-size: var(--layout-content-font-size);
      line-height: var(--layout-content-line-height);
      word-break: break-word;
    }

    .rich p,
    .rich ul,
    .rich ol {
      margin-top: 0;
      margin-bottom: 0.22em;
    }

    .rich ul,
    .rich ol {
      padding-left: 1.4em;
    }

    a {
      color: inherit;
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="page">
    <header class="header" data-section-key="basics">
      <div class="header-top">
        <div>
          <h1 class="name">{{ basics.name or title }}</h1>
          <div class="header-meta">
            {% if basics.phone %}<strong>{{ basics.phone }}</strong>{% endif %}
            {% if basics.phone and basics.email %} | {% endif %}
            {% if basics.email %}<strong>{{ basics.email }}</strong>{% endif %}
            {% if basics.location %}<br>意向城市：{{ basics.location }}{% endif %}
            {% if basics.job_target %}<br>求职方向：{{ basics.job_target }}{% endif %}
          </div>
        </div>
        {% if basics.avatar_data_uri %}
          <div class="avatar-wrap">
            <img class="avatar" src="{{ basics.avatar_data_uri }}" alt="avatar" style="object-position: 50% 50%; transform: translate({{ (50 - basics.avatar_crop.offset_x) * (0.45 + (basics.avatar_crop.scale - 1) * 0.9) }}%, {{ (50 - basics.avatar_crop.offset_y) * (0.45 + (basics.avatar_crop.scale - 1) * 0.9) }}%) scale({{ basics.avatar_crop.scale }});">
          </div>
        {% endif %}
      </div>
      {% if basics.summary %}
        <div class="summary-band rich">{{ basics.summary | safe }}</div>
      {% endif %}
    </header>

    {% if education %}
      <section class="section" data-section-key="education">
        <h2 class="section-title">教育经历</h2>
        {% for item in education %}
          <div class="entry">
            <div class="entry-head">
              <div class="entry-title">{{ item.school }}{% if item.major %} / {{ item.major }}{% endif %}{% if item.degree %} / {{ item.degree }}{% endif %}</div>
              <div class="entry-right">{{ item.start_date }}{% if item.start_date and item.end_date %} - {% endif %}{{ item.end_date }}</div>
            </div>
            {% if item.highlights %}<div class="rich">{{ item.highlights | safe }}</div>{% endif %}
          </div>
        {% endfor %}
      </section>
    {% endif %}

    {% for section in ordered_sections %}
      {% if section["key"] == "skills" %}
        <section class="section" data-section-key="{{ section['key'] }}">
          <h2 class="section-title">{{ section["title"] }}</h2>
          <div class="rich">{{ section["content"] | safe }}</div>
        </section>
      {% elif section["key"] == "experience" %}
        <section class="section" data-section-key="{{ section['key'] }}">
          <h2 class="section-title">{{ section["title"] }}</h2>
          {% for item in section["items"] %}
            <div class="entry">
              <div class="entry-head">
                <div class="entry-title"><span class="entry-tag">{{ item.entry_type or "实习经历" }}</span>{{ item.company }}</div>
                <div class="entry-right">{{ item.start_date }}{% if item.start_date and item.end_date %} - {% endif %}{{ item.end_date }}</div>
              </div>
              {% if item.department or item.role or item.location %}
                <div class="entry-subtitle">{{ item.department }}{% if item.department and item.role %} / {% endif %}{{ item.role }}{% if item.location %} · {{ item.location }}{% endif %}</div>
              {% endif %}
              {% if item.highlights %}<div class="rich">{{ item.highlights | safe }}</div>{% endif %}
            </div>
          {% endfor %}
        </section>
      {% elif section["key"] == "projects" %}
        <section class="section" data-section-key="{{ section['key'] }}">
          <h2 class="section-title">{{ section["title"] }}</h2>
          {% for item in section["items"] %}
            <div class="entry">
              <div class="entry-head">
                <div class="entry-title">{{ item.name }}</div>
                <div class="entry-right">{{ item.start_date }}{% if item.start_date and item.end_date %} - {% endif %}{{ item.end_date }}</div>
              </div>
              {% if item.description %}<div class="rich">{{ item.description | safe }}</div>{% endif %}
              {% if item.highlights %}<div class="rich">{{ item.highlights | safe }}</div>{% endif %}
            </div>
          {% endfor %}
        </section>
      {% elif section["key"] == "portfolio" %}
        <section class="section" data-section-key="{{ section['key'] }}">
          <h2 class="section-title">{{ section["title"] }}</h2>
          {% for item in section["items"] %}
            <div class="entry">
              <div class="entry-head">
                <div class="entry-title">{{ item.title }}</div>
              </div>
              {% if item.link %}<div class="rich"><a href="{{ item.link }}">{{ item.link }}</a></div>{% endif %}
              {% if item.summary %}<div class="rich">{{ item.summary | safe }}</div>{% endif %}
            </div>
          {% endfor %}
        </section>
      {% elif section["key"] == "research" or section["key"] == "honors" %}
        <section class="section" data-section-key="{{ section['key'] }}">
          <h2 class="section-title">{{ section["title"] }}</h2>
          {% for item in section["items"] %}
            <div class="entry">
              <div class="entry-head">
                <div class="entry-title">{{ item.title }}</div>
                <div class="entry-right">{{ item.label }}</div>
              </div>
              {% if item.summary %}<div class="rich">{{ item.summary | safe }}</div>{% endif %}
            </div>
          {% endfor %}
        </section>
      {% elif section.get("kind") == "custom" %}
        <section class="section" data-section-key="{{ section['key'] }}">
          <h2 class="section-title">{{ section["title"] }}</h2>
          {% for item in section["items"] %}
            <div class="entry">
              <div class="entry-head">
                <div class="entry-title">{{ item.title }}</div>
                <div class="entry-right">{{ item.start_date }}{% if item.start_date and item.end_date %} - {% endif %}{{ item.end_date }}</div>
              </div>
              {% if item.subtitle %}<div class="entry-subtitle">{{ item.subtitle }}</div>{% endif %}
              {% if item.description %}<div class="rich">{{ item.description | safe }}</div>{% endif %}
              {% if item.highlights %}<div class="rich">{{ item.highlights | safe }}</div>{% endif %}
            </div>
          {% endfor %}
        </section>
      {% endif %}
    {% endfor %}
  </div>
  <script>
    (function enableSectionJumping() {
      const notifyParent = function (sectionKey) {
        if (!sectionKey || window.parent === window) {
          return;
        }
        window.parent.postMessage({
          type: 'resume-preview-section-dblclick',
          sectionKey: sectionKey,
        }, window.location.origin);
      };

      document.addEventListener('dblclick', function (event) {
        const sectionNode = event.target.closest('[data-section-key]');
        if (!sectionNode) {
          return;
        }
        notifyParent(sectionNode.getAttribute('data-section-key'));
      });
    })();

    (function paginateResumePages() {
      const runPagination = function () {
        if (document.body.dataset.resumePaginated === '1') {
          return;
        }

        const sourcePage = document.querySelector('.page');
        if (!sourcePage) {
          return;
        }

        const headerNode = sourcePage.querySelector(':scope > .header');
        const sectionNodes = Array.from(sourcePage.querySelectorAll(':scope > .section'));
        const pageStack = document.createElement('div');
        pageStack.className = 'page-stack';
        sourcePage.after(pageStack);

        const createPage = function (withHeader) {
          const page = sourcePage.cloneNode(false);
          if (withHeader && headerNode) {
            page.appendChild(headerNode.cloneNode(true));
          }
          pageStack.appendChild(page);
          return page;
        };

        const pageHasBodyContent = function (page) {
          return Array.from(page.children).some(function (child) {
            return !child.classList.contains('header');
          });
        };

        const pageOverflows = function (page) {
          return page.scrollHeight > page.clientHeight + 1;
        };

        const buildSectionShell = function (sectionNode) {
          const sectionShell = sectionNode.cloneNode(false);
          const titleNode = sectionNode.querySelector(':scope > .section-title');
          if (titleNode) {
            sectionShell.appendChild(titleNode.cloneNode(true));
          }
          return sectionShell;
        };

        let currentPage = createPage(true);

        const ensureSectionShell = function (sectionNode) {
          let sectionShell = buildSectionShell(sectionNode);
          currentPage.appendChild(sectionShell);

          if (pageOverflows(currentPage) && pageHasBodyContent(currentPage)) {
            sectionShell.remove();
            currentPage = createPage(false);
            sectionShell = buildSectionShell(sectionNode);
            currentPage.appendChild(sectionShell);
          }

          return sectionShell;
        };

        const appendWholeSection = function (sectionNode) {
          const sectionClone = sectionNode.cloneNode(true);
          currentPage.appendChild(sectionClone);

          if (!pageOverflows(currentPage)) {
            return true;
          }

          sectionClone.remove();
          if (pageHasBodyContent(currentPage)) {
            currentPage = createPage(false);
            currentPage.appendChild(sectionNode.cloneNode(true));
            if (!pageOverflows(currentPage)) {
              return true;
            }
            currentPage.lastElementChild.remove();
          }

          return false;
        };

        const appendSectionByBlocks = function (sectionNode) {
          const blockNodes = Array.from(sectionNode.children).filter(function (child) {
            return !child.classList.contains('section-title');
          });
          let sectionShell = ensureSectionShell(sectionNode);

          blockNodes.forEach(function (blockNode) {
            const blockClone = blockNode.cloneNode(true);
            sectionShell.appendChild(blockClone);

            if (!pageOverflows(currentPage)) {
              return;
            }

            blockClone.remove();
            if (sectionShell.children.length <= 1 && !pageHasBodyContent(currentPage)) {
              sectionShell.appendChild(blockNode.cloneNode(true));
              return;
            }

            if (sectionShell.children.length <= 1) {
              sectionShell.remove();
            }
            currentPage = createPage(false);
            sectionShell = buildSectionShell(sectionNode);
            currentPage.appendChild(sectionShell);
            sectionShell.appendChild(blockNode.cloneNode(true));
          });

          if (sectionShell.children.length <= 1) {
            sectionShell.remove();
          }
        };

        sectionNodes.forEach(function (sectionNode) {
          if (!appendWholeSection(sectionNode)) {
            appendSectionByBlocks(sectionNode);
          }
        });

        sourcePage.remove();
        document.body.dataset.resumePaginated = '1';
      };

      if (document.readyState === 'complete') {
        requestAnimationFrame(runPagination);
      } else {
        window.addEventListener('load', function () {
          requestAnimationFrame(runPagination);
        }, { once: true });
      }
    })();
  </script>
</body>
</html>
